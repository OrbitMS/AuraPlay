{
  "$schema": "../node_modules/@tauri-apps/cli/schema.json",
  "productName": "metrolist-desktop",
  "version": "0.1.0",
  "identifier": "com.metrolist.desktop", 
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "metrolist-desktop",
        "width": 1100,
        "height": 720,
        "minWidth": 720,
        "minHeight": 520,
        "transparent": true,
        "windowEffects": {
          "effects": ["acrylic", "blur"]
        }
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$APPDATA/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}